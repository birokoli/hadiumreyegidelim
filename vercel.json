{
  "crons": [
    {
      "path": "/api/cron/auto-blog?phase=start",
      "schedule": "0 2,8,14 * * *"
    },
    {
      "path": "/api/cron/auto-blog?phase=outline",
      "schedule": "0 3,9,15 * * *"
    },
    {
      "path": "/api/cron/auto-blog?phase=draft",
      "schedule": "45 4,10,16 * * *"
    },
    {
      "path": "/api/cron/auto-blog?phase=publish",
      "schedule": "0 5,11,17 * * *"
    }
  ]
}
